# MindMap - Environment Variables

## AI Configuration (OpenRouter)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AI Models (Free tier - no credit card required)
# Options include: google/gemma-4-31b-it:free, openai/gpt-oss-20b:free,
# qwen/qwen3-next-80b-a3b-instruct:free, nousresearch/hermes-3-llama-3.1-405b:free
DEFAULT_MODEL=google/gemma-4-31b-it:free
MODEL_GENERATION=google/gemma-4-31b-it:free
MODEL_INTERVIEW=google/gemma-4-31b-it:free
MODEL_EXPANSION=google/gemma-4-31b-it:free
MODEL_RESEARCH=google/gemma-4-31b-it:free

## Research Configuration (Exa.ai)
EXA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXA_BASE_URL=https://api.exa.ai

# Exa Limits
MAX_RESULTS_PER_SEARCH=10
MAX_TOKENS_PER_RESULT=500
SEARCH_TIMEOUT_MS=15000

## Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

## Database (Neon PostgreSQL)
# Get your connection string from: https://neon.tech/dashboard
# Format: postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/mindmap?sslmode=require
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
